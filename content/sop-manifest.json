      "default_step_kind": "artifact",
      "step_kind_overrides": { "1": "read" }
    },
    "04": { "artifact_kind": "no_brainer_stack", "default_step_kind": "read", "step_kind_overrides": {} },
    "05": { "artifact_kind": "website_record", "default_step_kind": "read", "step_kind_overrides": {} },
    "06": { "artifact_kind": "lead_capture_kit", "default_step_kind": "read", "step_kind_overrides": {} },
    "07": { "artifact_kind": "warm_list", "default_step_kind": "read", "step_kind_overrides": {} },
    "08": { "artifact_kind": "content_loop", "default_step_kind": "read", "step_kind_overrides": {} },
    "09": { "artifact_kind": "automation_kit", "default_step_kind": "read", "step_kind_overrides": {} },
    "10": { "artifact_kind": "scoreboard_setup", "default_step_kind": "read", "step_kind_overrides": {} },
    "11": { "artifact_kind": "rules_file", "default_step_kind": "read", "step_kind_overrides": {} },
    "12": { "artifact_kind": "standing_brief", "default_step_kind": "read", "step_kind_overrides": {} }
