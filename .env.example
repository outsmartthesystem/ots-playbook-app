# ots-playbook-app environment. Copy to .env for local dev. Never commit .env.
# See the plan section 6.6 for the full list.

# --- core ---
DATABASE_URL=postgres://localhost:5432/ots_playbook
JWT_SECRET=                         # REQUIRED. Production-fatal if missing. Use a long random string.
NODE_ENV=development
APP_URL=http://localhost:3000       # D2: production is https://hustle.outsmartthesystem.org
PORT=3000

# --- admin bootstrap (createAdmin.js) ---
ADMIN_EMAIL=jay@outsmartthesystem.org
ADMIN_NAME=Jay
ADMIN_PASSWORD=                      # set once, run npm run createAdmin, then rotate

# --- email (Resend) ---
RESEND_API_KEY=
FROM_EMAIL=Jay <jay@outsmartthesystem.org>
DIGEST_DRY=1                         # 1 = print emails instead of sending (safe default)

# --- launch gate (plan section 5.6) ---
# LAUNCH_MODE=preview  -> admin-invited emails only, Stripe logs instead of emailing, beta banner.
# LAUNCH_MODE=production -> requires ALL four COUNSEL_SIGNOFF_* vars below, or /health reports ready:false.
LAUNCH_MODE=preview
COUNSEL_SIGNOFF_TOS=
COUNSEL_SIGNOFF_PRIVACY=
COUNSEL_SIGNOFF_MESSAGING=
COUNSEL_SIGNOFF_REPORTING=

# --- question channel (P3a). D6 SAFETY HOLD: stays 0 until counsel signs off on the
#     mandatory-reporting SOP AND the section 5.2.8 red-team harness passes. Jay flips this. ---
QUESTIONS_ENABLED=0
CLASSIFIER_API_KEY=
CLASSIFIER_MODEL=
CLASSIFIER_TIMEOUT_MS=8000
SAFETY_ALERT_TO=jay@outsmartthesystem.org
SAFETY_ALERT_BACKUP_TO=

# --- Stripe (P3b, additive; own endpoint) ---
STRIPE_WEBHOOK_SECRET=

# --- P4 copilot (deferred per D4 until after P3b) ---
# COPILOT_ENABLED=0
