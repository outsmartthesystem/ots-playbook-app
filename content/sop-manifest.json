{
  "version": 1,
  "notes": "Maps ingested playbook steps to kinds, artifacts, and gates (plan 4.1/4.2). Keys are 2-digit chapter numbers. Steps default to default_step_kind unless overridden by position. P0 ships chapters 00-03 fully mapped; 04-12 default to 'read' until P1 gives each its structured artifact (their artifact_kind is fixed here now so P1 need not re-decide).",
  "chapters": {
    "00": { "artifact_kind": null, "default_step_kind": "read", "step_kind_overrides": {} },
