      "artifact_kind": "voc_sheet",
      "default_step_kind": "artifact",
      "step_kind_overrides": { "1": "read", "5": "action", "9": "read" },
      "action_evidence": { "5": ["interviews_done", "dates"] },
      "presence_gate": {
        "kind": "one_per_bucket",
        "buckets": ["fears", "frustrations", "dream", "exact_words", "objections", "price"],
        "note": "D13: VoC cannot reach submitted until each bucket holds >= 1 quote."
      }
    },
    "02": {
